      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "macOS has no public API to detect ongoing screen recording. We scan for known sharing indicator windows (Zoom toolbar, Teams floating bar, etc.) — best effort, may miss some. For reliable hide use ⌘⌃M." } },
